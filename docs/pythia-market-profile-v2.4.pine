// ============================================================
// PYTHIA — Market Profile Value Area Alerts v2.4
// Pandora's Box / Olympus Committee
// ============================================================
// v2.4 CRITICAL FIXES:
//   - SESSION RESET BUG (the big one): v2.2 never reset session
//     state on charts with pre-market data. Volume profile
//     accumulated indefinitely across days, producing nonsense
//     VAH/VAL/POC values. This was the root cause of both:
//       (a) "191/200 tickers not calculated" on watchlist alerts
//       (b) markers floating at wrong vertical positions on chart
//     New logic: track lastSessionDay independently of inRTH,
//     reset on the FIRST in-session bar of each new day.
//
//   - BAR-INCLUSIVE SESSION DETECTION: bars that overlap RTH
//     (e.g., 1H bar covering 9:00-10:00 ET) now count as in-
//     session. Was: only bars STARTING in RTH counted.
//
//   - VA PRICE CACHING: VAH/VAL/POC persist outside the session
//     window. Alert system can evaluate them on any bar, not
//     just RTH. Eliminates stealth dropouts.
//
//   - REPAINT PROTECTION: plotshape markers now gate on
//     barstate.isconfirmed so historical markers stay anchored
//     to the bar where the alert actually fired.
//
//   - COOLDOWN SAFETY: handles non-time-based timeframes
//     (Renko, range bars) by clamping multiplier to >= 1.
//
//   - SYNTHETIC VOLUME FALLBACK: when volume==0/na (some ETFs,
//     futures contracts), the profile uses unit weighting so
//     the indicator still produces output. Marked "SynVol" in
//     the info table for transparency.
//
// v2.2 fixes: line.new() for proper chart scaling
// v2.1 fixes: Universal session detection
// v2.0 fixes: Volume distribution, prior-day VA, IB, etc.
// ============================================================
// REPO-SIDE CORRECTION (2026-07-15): the live TradingView copy of this
// script had drifted from this file -- the payload carried "secret" and
// "bar_time" fields this repo copy was missing. Reconciled here.
// The live copy also had the webhook secret HARDCODED as a literal
// string in the payload (a real credential, since redacted from git
// history and from this file) instead of read from an input field --
// that is how it ended up exposed via CSV/chat. Hardened: secret now
// comes from webhookSecret (input.string(""), filled in per-alert in
// TradingView's UI, same pattern every other TV-family script in this
// repo already uses) -- never hardcode the actual value in this file.
// Secret rotation is queued (Railway env + this field + re-arm all 4
// Pythia alerts, one coordinated pass) -- until that lands, the OLD
// secret value is still live and still was exposed; treat as compromised.
// ============================================================

//@version=5
indicator("Pythia Market Profile v2.4", overlay=true, max_bars_back=500, max_lines_count=50, max_boxes_count=20, max_labels_count=50)

// === INPUTS ===
sessionType      = input.string("RTH", "Session", options=["RTH", "ETH"])
numBins          = input.int(50, "Price bins", minval=20, maxval=100)
valueAreaPct     = input.float(70.0, "Value area %", minval=50, maxval=90) / 100.0
showLabels       = input.bool(true, "Show VAH/VAL/POC labels")
showPrevDay      = input.bool(true, "Show prior-day levels")
showFill         = input.bool(true, "Fill value area")
alertCooldownMin = input.int(120, "Alert cooldown (minutes)", minval=15)
webhookSecret    = input.string("", title="Webhook Secret", group="Webhook", tooltip="Must match PYTHIA_WEBHOOK_SECRET env var. Sent as the payload 'secret' field for server-side auth. Fill this in per-alert in TradingView's alert-creation UI -- NEVER hardcode the actual value in the script body.")

// === COOLDOWN (v2.4 — clamp for non-time-based charts) ===
tfMult       = timeframe.multiplier > 0 ? timeframe.multiplier : 1
cooldownBars = math.ceil(alertCooldownMin / tfMult)

// === SESSION DETECTION (v2.4 — bar-inclusive overlap with RTH window) ===
currentDate = year * 10000 + month * 100 + dayofmonth

barStartHour   = hour(time, "America/New_York")
barStartMinute = minute(time, "America/New_York")
barStartMin    = barStartHour * 60 + barStartMinute
barEndMin      = barStartMin + tfMult

// RTH window: 9:30 ET (570) to 16:00 ET (960)
// A bar is "in RTH" if it overlaps this window at all
inRTH = barStartMin < 960 and barEndMin > 570
inETH = true

inSession = sessionType == "RTH" ? inRTH : inETH

// === SESSION RESET (v2.4 — DECOUPLED from new-day detection) ===
// Track which calendar day we last reset for. Reset on the FIRST
// in-session bar of any new day, regardless of whether the chart
// also shows pre-market data for that day.
var int lastSessionDay = 0
isNewSession = inSession and currentDate != lastSessionDay

// === SESSION START BAR TRACKING ===
var int sessionStartBar = 0
if isNewSession
    sessionStartBar := bar_index

// === INITIAL BALANCE (v2.4 — bar-inclusive overlap) ===
// IB = first hour of RTH = 9:30-10:30 ET = minutes 570-630
inIBOverlap = barStartMin < 630 and barEndMin > 570

var float ibHigh = na
var float ibLow  = na
var bool  ibComplete = false

// === PRIOR-DAY VA STORAGE ===
var float prevVAH = na
var float prevVAL = na
var float prevPOC = na

// === VOLUME PROFILE STATE ===
var float sessionHigh = na
var float sessionLow  = na
var float[] volBins    = array.new_float(numBins, 0.0)
var float binSize      = na
var float cumSessionVol = 0.0

var float lastVAH = na
var float lastVAL = na
var float lastPOC = na

// === SESSION RESET LOGIC (the actual reset, all in one place) ===
if isNewSession
    // Roll prior-day cache from last session's final values
    if not na(lastVAH)
        prevVAH := lastVAH
    if not na(lastVAL)
        prevVAL := lastVAL
    if not na(lastPOC)
        prevPOC := lastPOC
    // Clear current session state
    sessionHigh   := high
    sessionLow    := low
    volBins       := array.new_float(numBins, 0.0)
    cumSessionVol := 0.0
    binSize       := na
    ibHigh        := na
    ibLow         := na
    ibComplete    := false
    // Mark this day as reset
    lastSessionDay := currentDate

// === IB ACCUMULATION ===
if inIBOverlap and inSession and not ibComplete
    ibHigh := na(ibHigh) ? high : math.max(ibHigh, high)
    ibLow  := na(ibLow)  ? low  : math.min(ibLow, low)

if not inIBOverlap and inSession and not ibComplete and not na(ibHigh)
    ibComplete := true

// === SESSION HIGH/LOW TRACKING ===
if inSession
    sessionHigh := na(sessionHigh) ? high : math.max(sessionHigh, high)
    sessionLow  := na(sessionLow)  ? low  : math.min(sessionLow, low)

// === VOLUME DISTRIBUTION INTO BINS ===
if inSession and not na(sessionHigh) and not na(sessionLow)
    range_ = sessionHigh - sessionLow
    if range_ > 0
        binSize := range_ / numBins
        loBinIdx = math.max(0, math.floor((low - sessionLow) / binSize))
        hiBinIdx = math.min(numBins - 1, math.floor((high - sessionLow) / binSize))
        binsHit = hiBinIdx - loBinIdx + 1
        // v2.4: synthetic unit volume fallback for tickers without consolidated volume
        effectiveVol = volume > 0 ? volume : 1.0
        volPerBin = binsHit > 0 ? effectiveVol / binsHit : effectiveVol
        for i = loBinIdx to hiBinIdx
            curVol = array.get(volBins, i)
            array.set(volBins, i, curVol + volPerBin)
        cumSessionVol += effectiveVol

// === FIND POC ===
var int   pocBin   = 0
var float pocVol   = 0.0
var float totalVol = 0.0

if inSession and not na(binSize) and binSize > 0
    pocVol   := 0.0
    totalVol := 0.0
    for i = 0 to numBins - 1
        bv = array.get(volBins, i)
        totalVol += bv
        if bv > pocVol
            pocVol := bv
            pocBin := i

// === VALUE AREA: expand outward from POC until 70% of volume is captured ===
var int valBin = 0
var int vahBin = 0

if inSession and totalVol > 0 and not na(binSize) and binSize > 0
    vaTarget = totalVol * valueAreaPct
    vaVol    = array.get(volBins, pocBin)
    loBin    = pocBin
    hiBin    = pocBin
    loopLimit = numBins
    count = 0
    while vaVol < vaTarget and count < loopLimit
        count += 1
        loNext = loBin > 0 ? array.get(volBins, loBin - 1) : 0.0
        hiNext = hiBin < numBins - 1 ? array.get(volBins, hiBin + 1) : 0.0
        if loNext >= hiNext and loBin > 0
            loBin -= 1
            vaVol += loNext
        else if hiBin < numBins - 1
            hiBin += 1
            vaVol += hiNext
        else
            break
    valBin := loBin
    vahBin := hiBin

// === CONVERT BINS TO PRICES (v2.4 — cache + reuse outside session) ===
liveLowGood = inSession and not na(binSize) and binSize > 0 and not na(sessionLow)
livePOC = liveLowGood ? sessionLow + (pocBin + 0.5) * binSize : na
liveVAL = liveLowGood ? sessionLow + valBin * binSize : na
liveVAH = liveLowGood ? sessionLow + (vahBin + 1) * binSize : na

// Cache live values when valid; reuse cached values outside session
if not na(liveVAH)
    lastVAH := liveVAH
    lastVAL := liveVAL
    lastPOC := livePOC

// Public values — non-na once we've ever computed a session
pocPrice = not na(livePOC) ? livePOC : lastPOC
valPrice = not na(liveVAL) ? liveVAL : lastVAL
vahPrice = not na(liveVAH) ? liveVAH : lastVAH

// === Poor high/low detection ===
highBinVol = totalVol > 0 and numBins > 1 ? array.get(volBins, numBins - 1) : 0.0
lowBinVol  = totalVol > 0 ? array.get(volBins, 0) : 0.0
poorHigh = totalVol > 0 and (highBinVol / totalVol) > 0.05
poorLow  = totalVol > 0 and (lowBinVol / totalVol) > 0.05

// === Volume quality (v2.4 — surfaces synthetic-volume fallback) ===
avgDailyVol = ta.sma(volume, 20)
relativeVol = avgDailyVol > 0 ? cumSessionVol / (avgDailyVol * 78) : 1.0
volQuality  = avgDailyVol == 0 ? "synthetic" : relativeVol > 1.3 ? "high" : relativeVol < 0.7 ? "thin" : "normal"

// === Value area migration ===
vaMigration = "unknown"
if not na(prevVAL) and not na(prevVAH) and not na(valPrice) and not na(vahPrice)
    if valPrice > prevVAH
        vaMigration := "higher"
    else if vahPrice < prevVAL
        vaMigration := "lower"
    else
        vaMigration := "overlapping"

// ================================================================
// === DISPLAY: line/box/label rendering (line-based for scaling) ==
// ================================================================

var line vahLine  = na
var line valLine  = na
var line pocLine  = na
var line pvahLine = na
var line pvalLine = na
var line ppocLine = na
var line ibhLine  = na
var line iblLine  = na
var box  vaBox    = na

var label vahLbl  = na
var label valLbl  = na
var label pocLbl  = na
var label pvahLbl = na
var label pvalLbl = na
var label ibhLbl  = na
var label iblLbl  = na
var label phLbl   = na
var label plLbl   = na

if inSession and not na(pocPrice)
    line.delete(vahLine)
    line.delete(valLine)
    line.delete(pocLine)
    line.delete(pvahLine)
    line.delete(pvalLine)
    line.delete(ppocLine)
    line.delete(ibhLine)
    line.delete(iblLine)
    box.delete(vaBox)
    label.delete(vahLbl)
    label.delete(valLbl)
    label.delete(pocLbl)
    label.delete(pvahLbl)
    label.delete(pvalLbl)
    label.delete(ibhLbl)
    label.delete(iblLbl)
    label.delete(phLbl)
    label.delete(plLbl)

    vahLine := line.new(sessionStartBar, vahPrice, bar_index, vahPrice,
         color=color.new(color.red, 20), width=2, style=line.style_solid)
    valLine := line.new(sessionStartBar, valPrice, bar_index, valPrice,
         color=color.new(color.green, 20), width=2, style=line.style_solid)
    pocLine := line.new(sessionStartBar, pocPrice, bar_index, pocPrice,
         color=color.new(color.yellow, 20), width=2, style=line.style_dotted)

    if showFill
        vaBox := box.new(sessionStartBar, vahPrice, bar_index, valPrice,
             border_color=color.new(color.blue, 100), bgcolor=color.new(color.blue, 90))

    if showLabels
        vahLbl := label.new(bar_index + 2, vahPrice, "VAH " + str.tostring(vahPrice, format.mintick),
             style=label.style_label_left, color=color.red, textcolor=color.white, size=size.small)
        valLbl := label.new(bar_index + 2, valPrice, "VAL " + str.tostring(valPrice, format.mintick),
             style=label.style_label_left, color=color.green, textcolor=color.white, size=size.small)
        pocLbl := label.new(bar_index + 2, pocPrice, "POC " + str.tostring(pocPrice, format.mintick),
             style=label.style_label_left, color=color.yellow, textcolor=color.black, size=size.small)

    if showPrevDay and not na(prevVAH)
        pvahLine := line.new(sessionStartBar, prevVAH, bar_index, prevVAH,
             color=color.new(color.red, 60), width=1, style=line.style_dashed)
        pvahLbl := label.new(bar_index + 4, prevVAH, "pVAH",
             style=label.style_label_left, color=color.new(color.red, 60), textcolor=color.white, size=size.tiny)
    if showPrevDay and not na(prevVAL)
        pvalLine := line.new(sessionStartBar, prevVAL, bar_index, prevVAL,
             color=color.new(color.green, 60), width=1, style=line.style_dashed)
        pvalLbl := label.new(bar_index + 4, prevVAL, "pVAL",
             style=label.style_label_left, color=color.new(color.green, 60), textcolor=color.white, size=size.tiny)
    if showPrevDay and not na(prevPOC)
        ppocLine := line.new(sessionStartBar, prevPOC, bar_index, prevPOC,
             color=color.new(color.yellow, 60), width=1, style=line.style_dashed)

    if ibComplete and not na(ibHigh)
        ibhLine := line.new(sessionStartBar, ibHigh, bar_index, ibHigh,
             color=color.new(color.orange, 30), width=1, style=line.style_solid)
        iblLine := line.new(sessionStartBar, ibLow, bar_index, ibLow,
             color=color.new(color.orange, 30), width=1, style=line.style_solid)
        ibhLbl := label.new(bar_index + 3, ibHigh, "IB-H",
             style=label.style_label_left, color=color.orange, textcolor=color.white, size=size.tiny)
        iblLbl := label.new(bar_index + 3, ibLow, "IB-L",
             style=label.style_label_left, color=color.orange, textcolor=color.white, size=size.tiny)

    if poorHigh
        phLbl := label.new(bar_index + 1, sessionHigh, "PH",
             style=label.style_xcross, color=color.new(color.red, 30), textcolor=color.red, size=size.tiny)
    if poorLow
        plLbl := label.new(bar_index + 1, sessionLow, "PL",
             style=label.style_xcross, color=color.new(color.green, 30), textcolor=color.green, size=size.tiny)

// === ALERT CONDITIONS (v2.4 — cooldown-gated, cached-price-aware) ===
var int barsSinceValAlert = 999
var int barsSinceVahAlert = 999
var int barsSinceIBAlert  = 999
barsSinceValAlert += 1
barsSinceVahAlert += 1
barsSinceIBAlert  += 1

valCrossBelow = not na(valPrice) and ta.crossunder(close, valPrice)
valAlert = valCrossBelow and barsSinceValAlert > cooldownBars
if valAlert
    barsSinceValAlert := 0

vahCrossAbove = not na(vahPrice) and ta.crossover(close, vahPrice)
vahAlert = vahCrossAbove and barsSinceVahAlert > cooldownBars
if vahAlert
    barsSinceVahAlert := 0

ibBreakUp   = ibComplete and inSession and not na(ibHigh) and ta.crossover(close, ibHigh)
ibBreakDown = ibComplete and inSession and not na(ibLow)  and ta.crossunder(close, ibLow)
ibAlert = (ibBreakUp or ibBreakDown) and barsSinceIBAlert > cooldownBars
if ibAlert
    barsSinceIBAlert := 0

// === COMMON PAYLOAD FIELDS ===
comFields = '"ticker":"' + syminfo.ticker + '",' +
     '"price":' + str.tostring(close) + ',' +
     '"val":' + str.tostring(nz(valPrice, 0), format.mintick) + ',' +
     '"vah":' + str.tostring(nz(vahPrice, 0), format.mintick) + ',' +
     '"poc":' + str.tostring(nz(pocPrice, 0), format.mintick) + ',' +
     '"prev_val":' + str.tostring(nz(prevVAL, 0), format.mintick) + ',' +
     '"prev_vah":' + str.tostring(nz(prevVAH, 0), format.mintick) + ',' +
     '"prev_poc":' + str.tostring(nz(prevPOC, 0), format.mintick) + ',' +
     '"va_migration":"' + vaMigration + '",' +
     '"ib_high":' + str.tostring(nz(ibHigh, 0), format.mintick) + ',' +
     '"ib_low":' + str.tostring(nz(ibLow, 0), format.mintick) + ',' +
     '"poor_high":' + (poorHigh ? 'true' : 'false') + ',' +
     '"poor_low":' + (poorLow ? 'true' : 'false') + ',' +
     '"volume_quality":"' + volQuality + '",' +
     '"secret":"' + webhookSecret + '",' +
     '"bar_time":"' + str.tostring(timenow) + '"'

// === FIRE ALERTS ===
if valAlert
    valInterp = volQuality == "high" ?
         "Price at VAL with high volume - institutional buying zone" :
         volQuality == "synthetic" ?
         "Price at VAL (volume estimated)" :
         "Price at VAL - watch for acceptance or rejection"
    alert('{"source":"pythia","event":"val_cross_below",' + comFields +
         ',"interpretation":"' + valInterp + '"}', alert.freq_once_per_bar)

if vahAlert
    vahInterp = volQuality == "high" ?
         "Price above VAH with high volume - potential breakout" :
         volQuality == "synthetic" ?
         "Price above VAH (volume estimated)" :
         "Price above VAH in thin extension - caution"
    alert('{"source":"pythia","event":"vah_cross_above",' + comFields +
         ',"interpretation":"' + vahInterp + '"}', alert.freq_once_per_bar)

if ibAlert
    ibEvent = ibBreakUp ? "ib_break_up" : "ib_break_down"
    ibInterp = ibBreakUp ?
         "IB breakout to upside - initiative buying" :
         "IB breakdown - initiative selling"
    alert('{"source":"pythia","event":"' + ibEvent + '",' + comFields +
         ',"interpretation":"' + ibInterp + '"}', alert.freq_once_per_bar)

// === ALERT VISUAL MARKERS (v2.4 — confirmed-bar gate prevents repaint) ===
plotValAlert = valAlert and barstate.isconfirmed
plotVahAlert = vahAlert and barstate.isconfirmed
plotIBUp     = ibBreakUp and ibAlert and barstate.isconfirmed
plotIBDown   = ibBreakDown and ibAlert and barstate.isconfirmed

plotshape(plotValAlert, title="VAL Cross", location=location.belowbar,
     style=shape.triangleup, color=color.green, size=size.small, text="VAL")
plotshape(plotVahAlert, title="VAH Cross", location=location.abovebar,
     style=shape.triangledown, color=color.red, size=size.small, text="VAH")
plotshape(plotIBUp, title="IB Break Up", location=location.abovebar,
     style=shape.diamond, color=color.orange, size=size.small, text="IB-BO")
plotshape(plotIBDown, title="IB Break Down", location=location.belowbar,
     style=shape.diamond, color=color.orange, size=size.small, text="IB-BD")

// === INFO TABLE ===
var table infoTbl = table.new(position.top_right, 3, 8, bgcolor=color.new(color.black, 80))
if barstate.islast and not na(pocPrice)
    table.cell(infoTbl, 0, 0, "PYTHIA v2.4", text_color=color.yellow, text_size=size.small)
    table.cell(infoTbl, 1, 0, syminfo.ticker, text_color=color.white, text_size=size.small)
    qualLabel = volQuality == "high" ? "HiVol" : volQuality == "thin" ? "ThinVol" : volQuality == "synthetic" ? "SynVol" : ""
    qualColor = volQuality == "high" ? color.lime : volQuality == "synthetic" ? color.aqua : color.orange
    table.cell(infoTbl, 2, 0, qualLabel, text_color=qualColor, text_size=size.tiny)
    table.cell(infoTbl, 0, 1, "VAH", text_color=color.red, text_size=size.tiny)
    table.cell(infoTbl, 1, 1, str.tostring(vahPrice, format.mintick), text_color=color.white, text_size=size.tiny)
    table.cell(infoTbl, 0, 2, "POC", text_color=color.yellow, text_size=size.tiny)
    table.cell(infoTbl, 1, 2, str.tostring(pocPrice, format.mintick), text_color=color.white, text_size=size.tiny)
    table.cell(infoTbl, 0, 3, "VAL", text_color=color.green, text_size=size.tiny)
    table.cell(infoTbl, 1, 3, str.tostring(valPrice, format.mintick), text_color=color.white, text_size=size.tiny)
    table.cell(infoTbl, 0, 4, "pVAH", text_color=color.new(color.red, 40), text_size=size.tiny)
    table.cell(infoTbl, 1, 4, not na(prevVAH) ? str.tostring(prevVAH, format.mintick) : "-",
         text_color=color.gray, text_size=size.tiny)
    table.cell(infoTbl, 0, 5, "pVAL", text_color=color.new(color.green, 40), text_size=size.tiny)
    table.cell(infoTbl, 1, 5, not na(prevVAL) ? str.tostring(prevVAL, format.mintick) : "-",
         text_color=color.gray, text_size=size.tiny)
    migColor = vaMigration == "higher" ? color.lime : vaMigration == "lower" ? color.red : color.gray
    table.cell(infoTbl, 0, 6, "VA Mig", text_color=color.gray, text_size=size.tiny)
    table.cell(infoTbl, 1, 6, vaMigration, text_color=migColor, text_size=size.tiny)
    if ibComplete and not na(ibHigh)
        table.cell(infoTbl, 2, 1, "IB-H: " + str.tostring(ibHigh, format.mintick),
             text_color=color.orange, text_size=size.tiny)
        table.cell(infoTbl, 2, 2, "IB-L: " + str.tostring(ibLow, format.mintick),
             text_color=color.orange, text_size=size.tiny)
    if poorHigh
        table.cell(infoTbl, 2, 3, "POOR HIGH", text_color=color.red, text_size=size.tiny)
    if poorLow
        table.cell(infoTbl, 2, 4, "POOR LOW", text_color=color.green, text_size=size.tiny)
