//@version=5
indicator("Circuit Breaker Monitor (VIX)", overlay=true)

// =============================================================================
// CIRCUIT BREAKER MONITOR - VIX
// =============================================================================
// 
// Monitors VIX for spikes and extreme levels, fires webhook alerts.
// 
// SETUP:
//   1. Add this indicator to VIX chart (5m or 15m timeframe recommended)
//   2. Create ONE alert: Condition → "Circuit Breaker Monitor (VIX)" → "Any alert() function call"
//   3. Webhook URL: https://pandoras-box-production.up.railway.app/webhook/circuit_breaker
//   4. Done - all triggers handled automatically
//
// =============================================================================

// Inputs
spike_threshold = input.float(15.0, "Spike Threshold (%)", step=1.0, group="Thresholds", tooltip="VIX up this % from prior close = spike")
extreme_level = input.float(25.0, "Extreme Level", step=1.0, group="Thresholds", tooltip="VIX crossing above this = extreme fear")
recovery_level = input.float(20.0, "Recovery Level", step=1.0, group="Thresholds", tooltip="VIX dropping below this after extreme = normalized")

// Get prior day's close
prior_close = request.security(syminfo.tickerid, "D", close[1], barmerge.gaps_off, barmerge.lookahead_on)

// Calculate change from prior close
change_from_close = ((close - prior_close) / prior_close) * 100

// State tracking
var string last_state = "NORMAL"
var bool was_extreme = false

// Determine current state
current_state = "NORMAL"

if close >= extreme_level
    current_state := "EXTREME"
    was_extreme := true
else if change_from_close >= spike_threshold
    current_state := "SPIKE"
else if was_extreme and close < recovery_level
    current_state := "RECOVERED"
    was_extreme := false

// Detect state changes and fire alerts
state_changed = current_state != last_state

if state_changed
    if current_state == "EXTREME" and last_state != "EXTREME"
        alert('{"type": "circuit_breaker", "trigger": "vix_extreme"}', alert.freq_once_per_bar)
    
    else if current_state == "SPIKE" and last_state == "NORMAL"
        alert('{"type": "circuit_breaker", "trigger": "vix_spike"}', alert.freq_once_per_bar)
    
    // Note: VIX recovery doesn't trigger spy_recovery - that's only for SPY
    // But we track it for display purposes
    
    last_state := current_state

// =============================================================================
// VISUAL DISPLAY
// =============================================================================

// Background color
bg_color = current_state == "EXTREME" ? color.new(color.red, 75) :
           current_state == "SPIKE" ? color.new(color.orange, 80) :
           na
bgcolor(bg_color, title="VIX Alert Background")

// Plot threshold lines
hline(extreme_level, "Extreme Level", color=color.red, linestyle=hline.style_dashed)
hline(recovery_level, "Recovery Level", color=color.green, linestyle=hline.style_dotted)

// Info table
var table infoTable = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 70), border_width=1)

if barstate.islast
    // State
    state_color = current_state == "EXTREME" ? color.red :
                  current_state == "SPIKE" ? color.orange :
                  color.gray
    table.cell(infoTable, 0, 0, "STATE", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 0, current_state, text_color=state_color, text_size=size.small)
    
    // VIX Level
    vix_color = close >= extreme_level ? color.red : close >= 20 ? color.orange : color.green
    table.cell(infoTable, 0, 1, "VIX", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 1, str.tostring(close, "#.##"), text_color=vix_color, text_size=size.small)
    
    // Change %
    chg_color = change_from_close >= 0 ? color.red : color.green  // Inverted - VIX up = bad
    table.cell(infoTable, 0, 2, "CHG", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(change_from_close, "#.##") + "%", text_color=chg_color, text_size=size.small)
    
    // Prior Close
    table.cell(infoTable, 0, 3, "PREV", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(prior_close, "#.##"), text_color=color.white, text_size=size.small)
