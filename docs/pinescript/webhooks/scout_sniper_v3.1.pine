//@version=5
indicator("Scout Sniper v3.1 (15m) - Tradeable/Ignore + VWAP Plan", overlay=true, max_lines_count=500, max_labels_count=500)

//==========================
// INPUTS
//==========================
use_tf_filter = input.bool(true, "Only run on 15m", group="A) Timeframe")
allowed_tf    = input.string("15", "Allowed TF", options=["5","15","30","60"], group="A) Timeframe")

rsi_len = input.int(14, "RSI Length", group="B) Signal Logic")
rsi_os  = input.int(30, "Oversold (Hook)", group="B) Signal Logic")
rsi_ob  = input.int(70, "Overbought (Hook)", group="B) Signal Logic")

vol_len  = input.int(20, "Volume MA Length", group="B) Signal Logic")
min_rvol = input.float(1.2, "Min RVOL (base)", step=0.1, group="B) Signal Logic")

use_tiers  = input.bool(true, "Use Tier A/B", group="B) Signal Logic")
tierA_rvol = input.float(1.6, "Tier A Min RVOL", step=0.1, group="B) Signal Logic")
tierB_rvol = input.float(1.1, "Tier B Min RVOL", step=0.1, group="B) Signal Logic")

require_candle = input.bool(true, "Require reversal candle", group="C) Candle Filter")
wick_ratio     = input.float(0.5, "Min wick ratio", step=0.1, group="C) Candle Filter")

cooldown_bars = input.int(4, "Cooldown (bars)", minval=1, group="D) Noise Control")

use_tradeable_filter   = input.bool(true, "Enable TRADEABLE/IGNORE filter", group="E) Tradeable Filter")
htf_tf                 = input.string("60", "HTF for regime", options=["60","240","D"], group="E) Tradeable Filter")
tierA_overrides_filter = input.bool(true, "Tier A overrides filter", group="E) Tradeable Filter")
// [M9] SMA HTF filter
use_sma_filter = input.bool(true, "Use SMA 50/120/200 HTF filter", group="E) Tradeable Filter")

// [M2] Time filter
use_time_filter = input.bool(true, "Enable Time Filter", group="E2) Time Filter")
avoid_first_15  = input.bool(true, "No signals first 15 min", group="E2) Time Filter")
avoid_lunch     = input.bool(true, "Avoid 12-1 PM ET", group="E2) Time Filter")

show_labels      = input.bool(true, "Show TRADEABLE/IGNORE label", group="F) Display")
labels_last_only = input.bool(true, "Only keep latest label", group="F) Display")
show_debug_table = input.bool(true, "Show debug table", group="F) Display")
// [L2] Show signal score
show_score = input.bool(true, "Show signal quality score", group="F) Display")

show_plan                  = input.bool(true, "Show Trade Plan (box + lines)", group="G) Trade Plan")
plan_only_when_tradeable   = input.bool(true, "Only show plan when TRADEABLE", group="G) Trade Plan")
wipe_plan_on_new_tradeable = input.bool(true, "Wipe plan on new TRADEABLE", group="G) Trade Plan")
wipe_plan_on_stop_hit      = input.bool(true, "Wipe plan if stop is hit", group="G) Trade Plan")
plan_extend_bars           = input.int(80, "Plan line length (bars)", minval=10, group="G) Trade Plan")

stop_mode       = input.string("Structure", "Stop mode", options=["Structure","ATR"], group="G) Trade Plan")
atr_stop_mult   = input.float(0.8, "ATR stop mult (ATR mode)", step=0.1, group="G) Trade Plan")
atr_buffer_mult = input.float(0.15, "Extra buffer (ATR mult)", step=0.05, group="G) Trade Plan")

use_vwap_targets = input.bool(true, "Use VWAP targets (TP1/TP2)", group="G) Trade Plan")
// [L3] R-multiple fallback targets
fallback_tp1_r   = input.float(1.5, "Fallback TP1 (R)", step=0.25, group="G) Trade Plan")
fallback_tp2_r   = input.float(2.0, "Fallback TP2 (R)", step=0.25, group="G) Trade Plan")
// [L3] Option to force R-multiple targets in trending environments
use_r_targets_trending = input.bool(false, "Force R-targets when trending", group="G) Trade Plan")

// Alerts
enable_alerts = input.bool(true, "Enable Alerts", group="H) Alerts")

//==========================
// TIMEFRAME GUARD
//==========================
tf_ok = (not use_tf_filter) or (timeframe.period == allowed_tf)

//==========================
// [M2] TIME FILTER
//==========================
market_hour_et = hour(time, "America/New_York")
market_min_et  = minute(time, "America/New_York")
is_first_15 = avoid_first_15 and market_hour_et == 9 and market_min_et < 45
is_lunch = avoid_lunch and market_hour_et == 12
time_ok = (not use_time_filter) or (not is_first_15 and not is_lunch)

//==========================
// CORE CALCS
//==========================
rsi      = ta.rsi(close, rsi_len)
rsi_prev = rsi[1]

vol_ma = ta.sma(volume, vol_len)
rvol   = (not na(vol_ma) and vol_ma > 0) ? (volume / vol_ma) : na

atr = ta.atr(14)

// ✅ 15m VWAP filter (quality gate)
vwap_15 = ta.vwap(hlc3)

// [M9] SMA 50/120/200 for HTF regime
sma50  = ta.sma(close, 50)
sma120 = ta.sma(close, 120)
sma200 = ta.sma(close, 200)
sma_bullish = close > sma50 and sma50 > sma120 and sma120 > sma200
sma_bearish = close < sma50 and sma50 < sma120 and sma120 < sma200
sma_mixed = not sma_bullish and not sma_bearish

// Candle anatomy
body       = math.abs(close - open)
upper_wick = high - math.max(open, close)
lower_wick = math.min(open, close) - low
range_     = high - low

// Reversal candles (simple)
is_hammer   = (lower_wick > (body * wick_ratio)) and (upper_wick < body)
is_shooting = (upper_wick > (body * wick_ratio)) and (lower_wick < body)
is_doji     = (range_ > 0) and (body <= (range_ * 0.12))

bull_candle = is_hammer or (is_doji and (lower_wick > range_ * 0.35)) or (close > open and close > open[1] and open < close[1])
bear_candle = is_shooting or (is_doji and (upper_wick > range_ * 0.35)) or (close < open and close < close[1] and open > open[1])

// RSI hooks
bull_hook = (rsi_prev < rsi_os) and (rsi > rsi_prev)
bear_hook = (rsi_prev > rsi_ob) and (rsi < rsi_prev)

// [L1] Structural level awareness — check if near prior swing high/low
swing_high_20 = ta.highest(high, 20)
swing_low_20  = ta.lowest(low, 20)
near_swing_high = high >= swing_high_20 - atr * 0.5
near_swing_low  = low <= swing_low_20 + atr * 0.5
// Don't go long into resistance, don't short into support
structural_long_ok  = not near_swing_high
structural_short_ok = not near_swing_low

// Base signals (✅ requires correct side of 15m VWAP + time filter)
base_long  = tf_ok and time_ok and (not na(rvol)) and (rvol >= min_rvol) and bull_hook and (close <= vwap_15) and ((not require_candle) or bull_candle)
base_short = tf_ok and time_ok and (not na(rvol)) and (rvol >= min_rvol) and bear_hook and (close >= vwap_15) and ((not require_candle) or bear_candle)

// Tier signals (✅ requires correct side of 15m VWAP + time filter)
tierA_long  = tf_ok and time_ok and (not na(rvol)) and (rvol >= tierA_rvol) and bull_hook and (close <= vwap_15) and ((not require_candle) or bull_candle)
tierA_short = tf_ok and time_ok and (not na(rvol)) and (rvol >= tierA_rvol) and bear_hook and (close >= vwap_15) and ((not require_candle) or bear_candle)

tierB_long  = tf_ok and time_ok and (not na(rvol)) and (rvol >= tierB_rvol) and bull_hook and (close <= vwap_15) and ((not require_candle) or bull_candle)
tierB_short = tf_ok and time_ok and (not na(rvol)) and (rvol >= tierB_rvol) and bear_hook and (close >= vwap_15) and ((not require_candle) or bear_candle)

raw_long  = use_tiers ? (tierA_long or tierB_long) : base_long
raw_short = use_tiers ? (tierA_short or tierB_short) : base_short

// Cooldown
var int last_long_bar  = na
var int last_short_bar = na

long_sig  = raw_long  and (na(last_long_bar)  or (bar_index - last_long_bar)  >= cooldown_bars)
short_sig = raw_short and (na(last_short_bar) or (bar_index - last_short_bar) >= cooldown_bars)

if long_sig
    last_long_bar := bar_index
if short_sig
    last_short_bar := bar_index

sig_tierA_long  = long_sig  and tierA_long
sig_tierA_short = short_sig and tierA_short
sig_tierB_long  = long_sig  and (not sig_tierA_long)
sig_tierB_short = short_sig and (not sig_tierA_short)

//==========================
// VWAPS (filter + targets)
//==========================
htf_close = request.security(syminfo.tickerid, htf_tf, close)
htf_vwap  = request.security(syminfo.tickerid, htf_tf, ta.vwap(hlc3))
htf_ok    = (not na(htf_close)) and (not na(htf_vwap))

htf_long_ok  = htf_ok and (htf_close >= htf_vwap)
htf_short_ok = htf_ok and (htf_close <= htf_vwap)

// [M9] Combined regime: VWAP stack + SMA alignment
combined_long_ok  = htf_long_ok and (not use_sma_filter or not sma_bearish)
combined_short_ok = htf_short_ok and (not use_sma_filter or not sma_bullish)

d_vwap = request.security(syminfo.tickerid, "D", ta.vwap(hlc3))

// Tradeable / ignore flags — [M9] now uses combined regime
tradeable_long  = false
tradeable_short = false

if not use_tradeable_filter
    tradeable_long  := long_sig
    tradeable_short := short_sig
else
    tradeable_long  := long_sig  and (combined_long_ok  or (tierA_overrides_filter and sig_tierA_long))
    tradeable_short := short_sig and (combined_short_ok or (tierA_overrides_filter and sig_tierA_short))

ignore_long  = long_sig  and (not tradeable_long)
ignore_short = short_sig and (not tradeable_short)

//==========================
// [L2] SIGNAL QUALITY SCORE
//==========================
var int sig_score = 0
if long_sig or short_sig
    sig_score := 0
    sig_score += time_ok ? 1 : 0
    sig_score += (long_sig and combined_long_ok) or (short_sig and combined_short_ok) ? 1 : 0
    sig_score += (not na(rvol) and rvol >= tierA_rvol) ? 2 : (not na(rvol) and rvol >= min_rvol) ? 1 : 0
    sig_score += (long_sig and sma_bullish) or (short_sig and sma_bearish) ? 1 : 0
    sig_score += (long_sig and structural_long_ok) or (short_sig and structural_short_ok) ? 1 : 0
    // Max score: 6 (time + regime + vol(2) + sma + structure)

//==========================
// PLOTTING
//==========================
plotshape(sig_tierA_long,  style=shape.diamond, location=location.belowbar, color=color.lime,     size=size.small, title="Tier A Long")
plotshape(sig_tierA_short, style=shape.diamond, location=location.abovebar, color=color.fuchsia, size=size.small, title="Tier A Short")

plotshape(sig_tierB_long,  style=shape.circle,  location=location.belowbar, color=color.new(color.lime, 35),     size=size.tiny, title="Tier B Long")
plotshape(sig_tierB_short, style=shape.circle,  location=location.abovebar, color=color.new(color.fuchsia, 35), size=size.tiny, title="Tier B Short")

bgcolor(tradeable_long ? color.new(color.lime, 88) : tradeable_short ? color.new(color.fuchsia, 88) : na)

plot(d_vwap,   "Daily VWAP", color=color.new(color.blue, 0), linewidth=2)
plot(htf_vwap, "HTF VWAP",   color=color.new(color.gray, 65), linewidth=1)
plot(vwap_15,  "15m VWAP (Signal Filter)", color=color.new(color.white, 70), linewidth=1)
// [M9] SMA overlays
plot(use_sma_filter ? sma50  : na, "SMA 50",  color=color.new(color.orange, 50), linewidth=1)
plot(use_sma_filter ? sma120 : na, "SMA 120", color=color.new(color.purple, 50), linewidth=1)
plot(use_sma_filter ? sma200 : na, "SMA 200", color=color.new(color.red, 50), linewidth=1)

//==========================
// LABELS (TRADEABLE / IGNORE)
//==========================
var label lastLbl = na

if show_labels and (tradeable_long or ignore_long or tradeable_short or ignore_short)
    if labels_last_only and not na(lastLbl)
        label.delete(lastLbl)

    // [L2] Append score to label
    score_txt = show_score ? " [" + str.tostring(sig_score) + "/6]" : ""

    if tradeable_long
        lastLbl := label.new(bar_index, low,  "TRADEABLE LONG" + score_txt,  style=label.style_label_up,   color=color.lime,    textcolor=color.black, size=size.small)
    else if ignore_long
        lastLbl := label.new(bar_index, low,  "IGNORE LONG" + score_txt,     style=label.style_label_up,   color=color.gray,    textcolor=color.white, size=size.small)
    else if tradeable_short
        lastLbl := label.new(bar_index, high, "TRADEABLE SHORT" + score_txt, style=label.style_label_down, color=color.fuchsia, textcolor=color.black, size=size.small)
    else if ignore_short
        lastLbl := label.new(bar_index, high, "IGNORE SHORT" + score_txt,    style=label.style_label_down, color=color.gray,    textcolor=color.white, size=size.small)

//==========================
// TRADE PLAN (NO FUNCTIONS TOUCHING GLOBALS)
//==========================
var line  plan_entry_line = na
var line  plan_sl_line    = na
var line  plan_tp1_line   = na
var line  plan_tp2_line   = na
var label plan_box        = na

var bool  plan_active = false
var bool  plan_isLong = na
var float plan_sl     = na

// For alert payload: last printed plan levels
var float last_plan_entry = na
var float last_plan_sl    = na
var float last_plan_tp1   = na
var float last_plan_tp2   = na
var bool  plan_printed_this_bar = false

do_clear_plan = false

// Wipe if stop hit
if wipe_plan_on_stop_hit and plan_active
    stop_hit = (plan_isLong and low <= plan_sl) or ((not plan_isLong) and high >= plan_sl)
    if stop_hit
        do_clear_plan := true

// Wipe on new TRADEABLE
new_tradeable = tradeable_long or tradeable_short
if show_plan and wipe_plan_on_new_tradeable and new_tradeable and plan_active
    do_clear_plan := true

if do_clear_plan
    line.delete(plan_entry_line)
    line.delete(plan_sl_line)
    line.delete(plan_tp1_line)
    line.delete(plan_tp2_line)
    label.delete(plan_box)
    plan_active := false
    plan_isLong := na
    plan_sl := na

fire_plan_long  = show_plan and long_sig  and ((not plan_only_when_tradeable) or tradeable_long)
fire_plan_short = show_plan and short_sig and ((not plan_only_when_tradeable) or tradeable_short)

// reset each bar
plan_printed_this_bar := false

if fire_plan_long or fire_plan_short
    plan_printed_this_bar := true

    isLong = fire_plan_long
    tierTxt = isLong ? (sig_tierA_long ? "Tier A" : "Tier B") : (sig_tierA_short ? "Tier A" : "Tier B")

    entry = close

    buffer = atr * atr_buffer_mult
    stop = entry
    if stop_mode == "ATR"
        stop := isLong ? (entry - atr * atr_stop_mult) : (entry + atr * atr_stop_mult)
    else
        stop := isLong ? (low - buffer) : (high + buffer)

    risk = isLong ? (entry - stop) : (stop - entry)
    if risk <= 0
        risk := atr * 0.5

    fb1 = isLong ? (entry + risk * fallback_tp1_r) : (entry - risk * fallback_tp1_r)
    fb2 = isLong ? (entry + risk * fallback_tp2_r) : (entry - risk * fallback_tp2_r)

    eps = syminfo.mintick * 2.0
    c1 = d_vwap
    c2 = htf_vwap

    c1_ok = (not na(c1)) and (isLong ? (c1 > entry + eps) : (c1 < entry - eps))
    c2_ok = (not na(c2)) and (isLong ? (c2 > entry + eps) : (c2 < entry - eps))

    tp1 = fb1
    tp2 = fb2

    // [L3] Determine if trending (use R-targets) or ranging (use VWAP targets)
    is_trending = sma_bullish or sma_bearish
    force_r = use_r_targets_trending and is_trending

    if use_vwap_targets and (c1_ok or c2_ok) and not force_r
        if isLong
            if c1_ok and c2_ok
                tp1 := math.min(c1, c2)
                tp2 := math.max(c1, c2)
            else
                tp1 := c1_ok ? c1 : c2
                tp2 := fb2
        else
            if c1_ok and c2_ok
                tp1 := math.max(c1, c2)
                tp2 := math.min(c1, c2)
            else
                tp1 := c1_ok ? c1 : c2
                tp2 := fb2

        if isLong and tp2 <= tp1 + eps
            tp2 := fb2
        if (not isLong) and tp2 >= tp1 - eps
            tp2 := fb2

    // Save plan levels for alerts
    last_plan_entry := entry
    last_plan_sl    := stop
    last_plan_tp1   := tp1
    last_plan_tp2   := tp2

    // Replace existing drawings
    line.delete(plan_entry_line)
    line.delete(plan_sl_line)
    line.delete(plan_tp1_line)
    line.delete(plan_tp2_line)
    label.delete(plan_box)

    x1 = bar_index
    x2 = bar_index + plan_extend_bars

    plan_entry_line := line.new(x1, entry, x2, entry, color=color.yellow, style=line.style_dashed, width=1)
    plan_sl_line    := line.new(x1, stop,  x2, stop,  color=color.red,    style=line.style_dotted, width=1)
    plan_tp1_line   := line.new(x1, tp1,   x2, tp1,   color=color.green,  style=line.style_dotted, width=1)
    plan_tp2_line   := line.new(x1, tp2,   x2, tp2,   color=color.teal,   style=line.style_dotted, width=1)

    rr_val = risk > 0 ? (isLong ? (tp1 - entry) / risk : (entry - tp1) / risk) : 0
    dirTxt = isLong ? "LONG" : "SHORT"
    txt =
         "TRADE PLAN (" + tierTxt + " " + dirTxt + ")\n" +
         "Entry: " + str.tostring(entry, "#.##") + "\n" +
         "Stop:  " + str.tostring(stop,  "#.##") + "\n" +
         "TP1:   " + str.tostring(tp1,   "#.##") + " (" + str.tostring(rr_val, "#.#") + "R)\n" +
         "TP2:   " + str.tostring(tp2,   "#.##") + "\n" +
         "Score: " + str.tostring(sig_score) + "/6"

    boxColor = isLong ? color.lime : color.fuchsia
    plan_box := label.new(x2, entry, txt, style=label.style_label_left, color=boxColor, textcolor=color.black, size=size.small)

    plan_active := true
    plan_isLong := isLong
    plan_sl := stop

//==========================
// UNIFIED ALERT
//==========================
any_signal = long_sig or short_sig

if enable_alerts and any_signal
    dir = long_sig ? "LONG" : "SHORT"
    tier = ((long_sig and sig_tierA_long) or (short_sig and sig_tierA_short)) ? "A" : "B"
    status = ((long_sig and tradeable_long) or (short_sig and tradeable_short)) ? "TRADEABLE" : "IGNORE"

    entry_str = plan_printed_this_bar ? str.tostring(last_plan_entry) : "null"
    sl_str    = plan_printed_this_bar ? str.tostring(last_plan_sl)    : "null"
    tp1_str   = plan_printed_this_bar ? str.tostring(last_plan_tp1)   : "null"
    tp2_str   = plan_printed_this_bar ? str.tostring(last_plan_tp2)   : "null"

    rvol_str = na(rvol) ? "null" : str.tostring(rvol, "#.##")
    htf_vwap_str = na(htf_vwap) ? "null" : str.tostring(htf_vwap, "#.##")
    d_vwap_str   = na(d_vwap)   ? "null" : str.tostring(d_vwap, "#.##")

    // [L2] Include score + [M9] SMA regime in alert
    sma_regime = sma_bullish ? "BULL" : sma_bearish ? "BEAR" : "MIXED"

    alert_msg =
         '{"ticker":"' + syminfo.ticker +
         '","strategy":"ScoutSniper"' +
         ',"timeframe":"' + timeframe.period +
         '","direction":"' + dir +
         '","tier":"' + tier +
         '","status":"' + status +
         '","score":' + str.tostring(sig_score) +
         ',"sma_regime":"' + sma_regime +
         '","price":' + str.tostring(close) +
         ',"rsi":' + str.tostring(rsi, "#.#") +
         ',"rvol":' + rvol_str +
         ',"plan_printed":' + (plan_printed_this_bar ? "true" : "false") +
         ',"entry":' + entry_str +
         ',"stop":'  + sl_str +
         ',"tp1":'   + tp1_str +
         ',"tp2":'   + tp2_str +
         ',"htf_tf":"' + htf_tf +
         '","htf_vwap":' + htf_vwap_str +
         ',"d_vwap":' + d_vwap_str +
         '}'

    alert(alert_msg, alert.freq_once_per_bar_close)

//==========================
// DEBUG TABLE
//==========================
var table dbg = table.new(position.bottom_right, 2, 9, bgcolor=color.new(color.black, 80))

if show_debug_table and barstate.islast
    table.cell(dbg, 0, 0, "TF OK", text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 1, 0, tf_ok ? "YES" : "NO", text_color=tf_ok ? color.lime : color.red, text_size=size.tiny)

    table.cell(dbg, 0, 1, "RVOL", text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 1, 1, na(rvol) ? "--" : (str.tostring(rvol, "#.##") + "x"), text_color=color.white, text_size=size.tiny)

    table.cell(dbg, 0, 2, "RSI", text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 1, 2, str.tostring(rsi, "#.#"), text_color=color.white, text_size=size.tiny)

    table.cell(dbg, 0, 3, "HOOK", text_color=color.gray, text_size=size.tiny)
    hookTxt = bull_hook ? "BULL" : bear_hook ? "BEAR" : "--"
    hookCol = bull_hook ? color.lime : bear_hook ? color.fuchsia : color.gray
    table.cell(dbg, 1, 3, hookTxt, text_color=hookCol, text_size=size.tiny)

    table.cell(dbg, 0, 4, "HTF OK", text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 1, 4, htf_ok ? "YES" : "NO", text_color=htf_ok ? color.lime : color.orange, text_size=size.tiny)

    table.cell(dbg, 0, 5, "REGIME", text_color=color.gray, text_size=size.tiny)
    regTxt = use_tradeable_filter ? (htf_long_ok ? "LONG" : htf_short_ok ? "SHORT" : "--") : "OFF"
    regCol = use_tradeable_filter ? (htf_long_ok ? color.lime : htf_short_ok ? color.fuchsia : color.gray) : color.gray
    table.cell(dbg, 1, 5, regTxt, text_color=regCol, text_size=size.tiny)

    // [M9] SMA regime display
    table.cell(dbg, 0, 6, "SMA", text_color=color.gray, text_size=size.tiny)
    sma_txt = sma_bullish ? "BULL" : sma_bearish ? "BEAR" : "MIXED"
    sma_col = sma_bullish ? color.lime : sma_bearish ? color.fuchsia : color.orange
    table.cell(dbg, 1, 6, sma_txt, text_color=sma_col, text_size=size.tiny)

    // [M2] Time filter display
    table.cell(dbg, 0, 7, "TIME", text_color=color.gray, text_size=size.tiny)
    time_txt = time_ok ? "OK" : is_first_15 ? "EARLY" : "LUNCH"
    table.cell(dbg, 1, 7, time_txt, text_color=time_ok ? color.lime : color.red, text_size=size.tiny)

    // [L2] Score display
    table.cell(dbg, 0, 8, "SCORE", text_color=color.gray, text_size=size.tiny)
    table.cell(dbg, 1, 8, str.tostring(sig_score) + "/6", text_color=sig_score >= 4 ? color.lime : sig_score >= 2 ? color.orange : color.red, text_size=size.tiny)
