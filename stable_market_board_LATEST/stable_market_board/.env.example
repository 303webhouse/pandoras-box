# Polygon.io API key. Get one at https://polygon.io/dashboard/keys
# Stocks Starter plan ($29/mo) is sufficient.
POLYGON_API_KEY=your_key_here

# How many years of daily history to pull on initial ingestion.
# Default 5 is enough for 200DMA, 52w highs, multi-year RS.
HISTORY_YEARS=5

# Local path to DuckDB file. Default: ./data/market.duckdb
DB_PATH=./data/market.duckdb

# Path to the universe CSV (the one you edit). Default: ./data/universe.csv
UNIVERSE_PATH=./data/universe.csv
