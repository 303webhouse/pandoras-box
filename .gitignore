# Crypto Scalper (separate project)
crypto-scalper/

# Python cache
__pycache__/
*.pyc
*.pyo

# Environment variables (NEVER commit secrets)
.env
*.env
config/.env
.mcp.json

# Logs
*.log
bot_startup.log

# Pivot runtime state
pivot/state/
pivot/cache/

# Backend runtime state (generated at runtime; do not commit)
data/bias_history.json
data/weekly_baseline.json
data/archives/

# Raw RH activity CSV exports — contains full trade history with cost basis.
# Inputs to scripts/sync_rh_csv.py. Never commit.
data/rh_csv/

# DB snapshots taken before destructive sync operations (e.g. RH CSV sync apply).
# Contain raw position data including cost basis. Never commit.
backups/

# Backups
*.backup.*
*.bak

# UW forward-logger cache (paid data, do not commit — AEGIS §10.2)
data/cache/uw/
*.parquet

# Archives
*.zip

# Debug/diagnostic output
diagnose_output.json

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/

# Committee deep review working files
committee-reviews/

# Local scripts (machine-specific)
start_discord_bot.bat
start_discord_bot.ps1
start_discord_bot_silent.vbs

# Skill build artifacts (regenerated by scripts/package-skill.{ps1,bat})
dist/

# Perf architecture brief — Chrome DevTools traces (regenerable, often 100MB+)
docs/strategy-reviews/perf-trace-*.json

# Session scratch / scratch dumps (transient, never commit)
tmp_*.json
*_chunks.txt
all_chunks_flat.txt
/one
data/_*.json
scripts/retrospective_output.json
# Windows Explorer folder metadata
desktop.ini
